{
  "uid": "adventurelog-live-data",
  "title": "Live Data Monitoring",
  "tags": ["adventurelog", "live", "stream"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "row", "title": "Event Throughput",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "timeseries", "title": "Events per Minute (rolling 60s) by Topic",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_events_per_minute", "refId": "A", "legendFormat": "{{topic}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []}
    },
    {
      "id": 3, "type": "row", "title": "Event Totals by Topic",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}
    },
    {
      "id": 4, "type": "stat", "title": "Clicks Processed",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_events_processed_total{topic=\"clicks\"}", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "stat", "title": "Rates Processed",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_events_processed_total{topic=\"rates\"}", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 6, "type": "stat", "title": "Comments Processed",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_events_processed_total{topic=\"comments\"}", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 7, "type": "row", "title": "Rating Balance",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}
    },
    {
      "id": 8, "type": "bargauge", "title": "Rating Distribution (1–5 Stars)",
      "gridPos": {"h": 6, "w": 16, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_rating_star_total", "refId": "A", "legendFormat": "{{stars}} stars"}],
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "showUnfilled": true},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 9, "type": "stat", "title": "Positive Ratings (≥ 4★)",
      "gridPos": {"h": 3, "w": 8, "x": 16, "y": 15},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_rating_positive_total", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}
    },
    {
      "id": 10, "type": "stat", "title": "Negative Ratings (< 4★)",
      "gridPos": {"h": 3, "w": 8, "x": 16, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_rating_negative_total", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}}, "overrides": []}
    },
    {
      "id": 11, "type": "row", "title": "Duplicate Events",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21}
    },
    {
      "id": 12, "type": "stat", "title": "Duplicate Clicks",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_duplicate_clicks_total", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}, "overrides": []}
    },
    {
      "id": 13, "type": "stat", "title": "Duplicate Rates",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_duplicate_rates_total", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}, "overrides": []}
    },
    {
      "id": 14, "type": "stat", "title": "Duplicate Comments",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_duplicate_comments_total", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}, "overrides": []}
    },
    {
      "id": 15, "type": "row", "title": "User Metrics",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26}
    },
    {
      "id": 16, "type": "stat", "title": "Unique Active Users",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_unique_active_users", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 17, "type": "stat", "title": "Avg Actions per User",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_avg_actions_per_user", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 18, "type": "stat", "title": "Avg User Visit Count (Redis)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_avg_user_visits", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 19, "type": "timeseries", "title": "Unique Active Users Over Time",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_unique_active_users", "refId": "A", "legendFormat": "users"}],
      "options": {"legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 20}}, "overrides": []}
    },
    {
      "id": 20, "type": "row", "title": "Location Metrics",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31}
    },
    {
      "id": 21, "type": "stat", "title": "Unique Active Locations",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_unique_active_locations", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 22, "type": "stat", "title": "Avg Actions per Location",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_avg_actions_per_location", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 23, "type": "stat", "title": "Avg Location Rating (Redis)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_avg_location_rating", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "min": 1, "max": 5, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 3}, {"color": "green", "value": 4}]}}, "overrides": []}
    },
    {
      "id": 24, "type": "stat", "title": "Avg Location Popularity (Redis)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_avg_location_popularity", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 25, "type": "row", "title": "Live Drift Detection",
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36}
    },
    {
      "id": 26, "type": "stat", "title": "Drift Detected",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_drift_detected", "refId": "A", "legendFormat": ""}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "mappings": [{"type": "value", "options": {"0": {"text": "NO DRIFT", "color": "green", "index": 0}, "1": {"text": "DRIFT !", "color": "red", "index": 1}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 27, "type": "gauge", "title": "MMD Distance",
      "gridPos": {"h": 4, "w": 10, "x": 4, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_drift_mmd_distance", "refId": "A", "legendFormat": ""}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 4, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.1}]}}, "overrides": []}
    },
    {
      "id": 28, "type": "gauge", "title": "P-Value (< 0.05 = drift)",
      "gridPos": {"h": 4, "w": 10, "x": 14, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consumer_drift_p_val", "refId": "A", "legendFormat": ""}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 4, "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0.05}]}}, "overrides": []}
    }
  ]
}
