{
  "uid": "gemspot-serving",
  "title": "GemSpot Serving",
  "tags": ["adventurelog", "gemspot", "serving", "mlops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Serving Health",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Model Loaded",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_model_loaded)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "NOT LOADED", "color": "red"}, "1": {"text": "LOADED", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests / min",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(gemspot_requests_total{endpoint=\"/recommend\"}[1m])) * 60", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "reqpm"}, "overrides": []}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Recent Error Rate",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_error_rate_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.02}, {"color": "red", "value": 0.05}]}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Recent P95 Latency",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_latency_p95_ms_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 250}, {"color": "red", "value": 500}]}
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Operational Metrics",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (status_code) (rate(gemspot_requests_total{endpoint=\"/recommend\"}[5m]))", "refId": "A", "legendFormat": "{{status_code}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency P95 and Mean",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "max(gemspot_latency_p95_ms_recent)", "refId": "A", "legendFormat": "recent p95"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(gemspot_request_latency_seconds_bucket{endpoint=\"/recommend\"}[5m]))) * 1000", "refId": "B", "legendFormat": "5m p95"},
        {"expr": "sum(rate(gemspot_request_latency_seconds_sum{endpoint=\"/recommend\"}[5m])) / sum(rate(gemspot_request_latency_seconds_count{endpoint=\"/recommend\"}[5m])) * 1000", "refId": "C", "legendFormat": "5m mean"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Model Version Traffic",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (model_version) (rate(gemspot_model_traffic_total[5m]))", "refId": "A", "legendFormat": "{{model_version}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Unavailable / Inference Errors",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(gemspot_model_unavailable_total[5m]))", "refId": "A", "legendFormat": "model unavailable"},
        {"expr": "sum by (error_type) (rate(gemspot_request_errors_total[5m]))", "refId": "B", "legendFormat": "{{error_type}}"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 11,
      "type": "row",
      "title": "Model Output Monitoring",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Recent Mean Score",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gemspot_score_mean_recent", "refId": "A", "legendFormat": "{{model_version}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Recent Candidate-to-TopK Ratio",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gemspot_topk_ratio_mean_recent", "refId": "A", "legendFormat": "{{model_version}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Average Candidates Scored",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(gemspot_candidates_scored_sum[5m])) / sum(rate(gemspot_candidates_scored_count[5m]))", "refId": "A", "legendFormat": "avg candidates"}],
      "options": {"legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 15,
      "type": "heatmap",
      "title": "Score Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (le) (rate(gemspot_score_distribution_bucket[5m]))", "refId": "A", "format": "heatmap"}],
      "options": {"calculate": false},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 16,
      "type": "heatmap",
      "title": "TopK Ratio Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (le) (rate(gemspot_topk_ratio_bucket[5m]))", "refId": "A", "format": "heatmap"}],
      "options": {"calculate": false},
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 17,
      "type": "row",
      "title": "Feedback Monitoring",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 37}
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Recent CTR",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 38},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_ctr_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "green", "value": 0.03}]}
        },
        "overrides": []
      }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Recent Fallback Rate",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 38},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_fallback_rate_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.1}]}
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Negative Feedback Rate",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 38},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_negative_feedback_rate_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.2}, {"color": "red", "value": 0.35}]}
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Comment Volume",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 38},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(gemspot_comment_volume_recent)", "refId": "A"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Impressions, Clicks, Comments",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(gemspot_impressions_total[5m]))", "refId": "A", "legendFormat": "impressions"},
        {"expr": "sum(rate(gemspot_feedback_clicks_total[5m]))", "refId": "B", "legendFormat": "clicks"},
        {"expr": "sum(rate(gemspot_feedback_comments_total[5m]))", "refId": "C", "legendFormat": "comments"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 23,
      "type": "bargauge",
      "title": "Rating Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (rating) (gemspot_feedback_ratings_total)", "refId": "A", "legendFormat": "{{rating}} star"}],
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "showUnfilled": true},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    }
  ]
}
