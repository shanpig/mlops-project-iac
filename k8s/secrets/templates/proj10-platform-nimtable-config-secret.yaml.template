apiVersion: v1
kind: Secret
metadata:
  name: nimtable-config
  namespace: proj10-platform
type: Opaque
stringData:
  config.yaml: |
    server:
      port: 8182
      host: 0.0.0.0
    database:
      url: __NIMTABLE_CONFIG_DB_URL__
      username: __NIMTABLE_CONFIG_DB_USERNAME__
      password: __NIMTABLE_CONFIG_DB_PASSWORD__
