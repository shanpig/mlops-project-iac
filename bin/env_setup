#!/usr/bin/env bash

set -e

# Paths
BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$BASE_DIR/.env"

# ANSIBLE_DIR="$BASE_DIR/ansible"
# ANSIBLE_CFG_FILENAME="ansible.cfg"
# ANSIBLE_CFG_FILEPATH="$ANSIBLE_DIR/$ANSIBLE_CFG_FILENAME"
# ANSIBLE_CFG_TEMPLATE_FILENAME="$ANSIBLE_CFG_FILENAME.template"
# ANSIBLE_CFG_TEMPLATE_FILEPATH="$ANSIBLE_DIR/$ANSIBLE_CFG_TEMPLATE_FILENAME"

# ANSIBLE_INVENTORY_FILENAME="inventory.yml"
# ANSIBLE_INVENTORY_FILEPATH="$ANSIBLE_DIR/$ANSIBLE_INVENTORY_FILENAME"
# ANSIBLE_INVENTORY_TEMPLATE_FILENAME="$ANSIBLE_INVENTORY_FILENAME.template"
# ANSIBLE_INVENTORY_TEMPLATE_FILEPATH="$ANSIBLE_DIR/$ANSIBLE_INVENTORY_TEMPLATE_FILENAME"

KVM_CLOUDS_DIR="$BASE_DIR/tf/kvm"
CHI_CLOUDS_DIR="$BASE_DIR/tf/chi"
CLOUDS_YAML_FILENAME="clouds.yaml"
CLOUDS_YAML_TEMPLATE_FILENAME="$CLOUDS_YAML_FILENAME.template"
SECRETS_TEMPLATE_DIR="$BASE_DIR/k8s/secrets/templates"
SECRETS_OUTPUT_DIR="$BASE_DIR/k8s/secrets/plain"

SSH_CONFIG_TEMPLATE="$BASE_DIR/ssh-config.template"
SSH_CONFIG_PATH="$HOME/.ssh/config"

# Read variables from .env
if [ ! -f "$ENV_FILE" ]; then
    echo ".env file not found at $ENV_FILE"
    exit 1
fi

# Utility for parsing .env values
function get_env {
    local key="$1"
    local line
    local value

    line="$(grep -E "^${key}[[:space:]]*=" "$ENV_FILE" | tail -n 1 || true)"
    value="${line#*=}"
    value="$(echo "$value" | sed -E "s/^[[:space:]]+|[[:space:]]+$//g")"

    if [[ "$value" =~ ^\".*\"$ ]] || [[ "$value" =~ ^\'.*\'$ ]]; then
        value="${value:1:${#value}-2}"
    fi

    echo "$value"
}

FLOATING_IP=$(get_env FLOATING_IP)
KVM_APPLICATION_CREDENTIAL_ID=$(get_env KVM_APPLICATION_CREDENTIAL_ID)
KVM_APPLICATION_CREDENTIAL_SECRET=$(get_env KVM_APPLICATION_CREDENTIAL_SECRET)
CHI_APPLICATION_CREDENTIAL_ID=$(get_env CHI_APPLICATION_CREDENTIAL_ID)
CHI_APPLICATION_CREDENTIAL_SECRET=$(get_env CHI_APPLICATION_CREDENTIAL_SECRET)

if [ -z "$FLOATING_IP" ] || [ -z "$KVM_APPLICATION_CREDENTIAL_ID" ] || [ -z "$KVM_APPLICATION_CREDENTIAL_SECRET" ] || [ -z "$CHI_APPLICATION_CREDENTIAL_ID" ] || [ -z "$CHI_APPLICATION_CREDENTIAL_SECRET" ]; then
    echo "One or more required env variables missing."
    exit 1
fi

function escape_sed_replacement {
    echo "$1" | sed -e 's/[\/&]/\\&/g'
}

function render_secrets_from_templates {
    if [ ! -d "$SECRETS_TEMPLATE_DIR" ]; then
        echo "Secrets template directory not found at $SECRETS_TEMPLATE_DIR"
        exit 1
    fi

    mkdir -p "$SECRETS_OUTPUT_DIR"

    # Secrets used by templates.
    local keys=(
        MINIO_ACCESS_KEY
        MINIO_SECRET_KEY
        PLATFORM_POSTGRES_HOST
        PLATFORM_POSTGRES_USERNAME
        PLATFORM_POSTGRES_PASSWORD
        PLATFORM_POSTGRES_DBNAME
        NIMTABLE_POSTGRES_DBNAME
        AIRFLOW_ADMIN_USERNAME
        AIRFLOW_ADMIN_PASSWORD
        AIRFLOW_ADMIN_FIRSTNAME
        AIRFLOW_ADMIN_LASTNAME
        AIRFLOW_ADMIN_EMAIL
        NIMTABLE_JWT_SECRET
        NIMTABLE_ADMIN_USERNAME
        NIMTABLE_ADMIN_PASSWORD
        STAGING_POSTGRES_PASSWORD
        STAGING_SECRET_KEY
        STAGING_DJANGO_ADMIN_USERNAME
        STAGING_DJANGO_ADMIN_PASSWORD
        STAGING_DJANGO_ADMIN_EMAIL
        CANARY_POSTGRES_PASSWORD
        CANARY_SECRET_KEY
        CANARY_DJANGO_ADMIN_USERNAME
        CANARY_DJANGO_ADMIN_PASSWORD
        CANARY_DJANGO_ADMIN_EMAIL
        PRODUCTION_POSTGRES_PASSWORD
        PRODUCTION_SECRET_KEY
        PRODUCTION_DJANGO_ADMIN_USERNAME
        PRODUCTION_DJANGO_ADMIN_PASSWORD
        PRODUCTION_DJANGO_ADMIN_EMAIL
    )

    local platform_postgres_host
    platform_postgres_host="$(get_env PLATFORM_POSTGRES_HOST)"
    if [ -z "$platform_postgres_host" ] || [ "$platform_postgres_host" = "postgres" ]; then
        platform_postgres_host="proj10-postgres.proj10-production.svc.cluster.local"
        echo "PLATFORM_POSTGRES_HOST is empty or set to 'postgres'. Falling back to ${platform_postgres_host} for secret rendering."
    fi
    local nimtable_postgres_dbname
    nimtable_postgres_dbname="$(get_env NIMTABLE_POSTGRES_DBNAME)"
    if [ -z "$nimtable_postgres_dbname" ]; then
        nimtable_postgres_dbname="nimtable_catalog"
        echo "NIMTABLE_POSTGRES_DBNAME is empty. Falling back to ${nimtable_postgres_dbname} for Nimtable secret rendering."
    fi

    for template in "$SECRETS_TEMPLATE_DIR"/*.yaml.template; do
        [ -e "$template" ] || continue

        local output
        output="$SECRETS_OUTPUT_DIR/$(basename "${template%.template}")"
        cp "$template" "$output"

        for key in "${keys[@]}"; do
            local value
            local escaped
            if [ "$key" = "PLATFORM_POSTGRES_HOST" ]; then
                value="$platform_postgres_host"
            elif [ "$key" = "NIMTABLE_POSTGRES_DBNAME" ]; then
                value="$nimtable_postgres_dbname"
            else
                value="$(get_env "$key")"
            fi
            escaped="$(escape_sed_replacement "$value")"
            sed -i.bak "s|__${key}__|${escaped}|g" "$output"
        done

        rm -f "${output}.bak"
        echo "Rendered $(basename "$output")"
    done

    echo "Rendered Kubernetes Secret manifests to $SECRETS_OUTPUT_DIR"
}

# # Update ansible.cfg, replace "A.B.C.D" with the value of FLOATING_IP
# echo "Stubbing env variables in $ANSIBLE_CFG_TEMPLATE_FILEPATH..."
# if [ ! -f "$ANSIBLE_CFG_TEMPLATE_FILEPATH" ]; then
